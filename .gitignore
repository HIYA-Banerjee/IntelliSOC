# IntelliSOC .gitignore

# Python compiled files
__pycache__/
*.py[cod]

# Virtual environments
venv/
.env

# Environment variables
.env

# Pytest cache
.pytest_cache/

# IDE / editor files
.vscode/
.idea/
*.swp

# Build / distribution
build/
dist/
*.egg-info/

# OS files
.DS_Store
Thumbs.db

# Local artifacts (Gemini)
.gemini/

# Large data files
*.h5
*.model
