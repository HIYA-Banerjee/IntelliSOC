# Dockerfile for Packet Capture Agent
FROM python:3.11-slim

# Install system dependencies including libpcap for raw socket sniffing
RUN apt-get update && apt-get install -y \
    build-essential \
    libpcap-dev \
    tcpdump \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Copy dependencies
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Copy source code
COPY . .

# Run packet capture script
CMD ["python", "packet_capture/capture.py"]
