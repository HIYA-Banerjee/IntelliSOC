# Supabase Project Configuration
SUPABASE_URL=https://your-supabase-project.supabase.co
SUPABASE_KEY=your-supabase-anon-or-service-role-key
SUPABASE_JWT_SECRET=your-supabase-jwt-signing-secret

# Apache Kafka Configuration
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# AI Security Copilot Settings
GEMINI_API_KEY=

# SMTP Email Alert Settings (SMTP server details)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=alerts@intellisoc.local
SMTP_PASSWORD=yoursecretpassword
SMTP_FROM=soc-alert@intellisoc.local
SMTP_TO=security-analyst@intellisoc.local

# Telegram Bot Alert Settings
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Network Sniffing Configuration
# Set to True to bypass Scapy raw capture and run the high-fidelity mock stream generator
SIMULATION_MODE=True
CAPTURE_INTERFACE=
MAX_PACKETS_TO_CAPTURE=1000

# Backend and Dashboard Configuration
BACKEND_API_URL=http://localhost:8000
DASHBOARD_PORT=8501
API_PORT=8000
